<div class="space-y-6">
  <!-- Breadcrumb -->
  <nav class="flex items-center space-x-2 text-sm">
    <a href="/admin/builds" class="text-sky-600 hover:text-sky-700">Builds</a>
    <span class="text-slate-400">/</span>
    <span class="text-slate-600"><%= @build.name %></span>
  </nav>

  <!-- Build Header -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center space-x-3">
          <h1 class="text-2xl font-bold text-slate-800"><%= @build.name %></h1>
          <% if @build.discipline.present? %>
            <span class="px-2.5 py-1 text-xs font-medium bg-indigo-50 text-indigo-600 rounded-full uppercase"><%= @build.discipline %></span>
          <% end %>
        </div>
        <p class="text-slate-500 mt-1">
          Created by <a href="/admin/users/<%= @build.user_id %>" class="text-sky-600 hover:text-sky-700"><%= @build.user.username %></a>
          on <%= @build.created_at.strftime('%B %d, %Y') %>
        </p>
      </div>
      <div class="flex items-center space-x-3">
        <form action="/admin/builds/<%= @build.id %>" method="post" class="inline" onsubmit="return confirm('Are you sure you want to delete this build?');">
          <input type="hidden" name="_method" value="delete">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" class="px-4 py-2 text-sm font-medium text-red-600 hover:text-red-700 hover:bg-red-50 rounded-xl transition-colors">Delete Build</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Build Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Total Components</p>
          <p class="text-3xl font-bold text-slate-800 mt-1"><%= @build_components.count %></p>
        </div>
        <div class="p-3 bg-sky-100 rounded-xl">
          <svg class="w-6 h-6 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Total Weight</p>
          <p class="text-3xl font-bold text-emerald-600 mt-1"><%= @build.total_weight_oz ? "#{@build.total_weight_oz} oz" : '—' %></p>
        </div>
        <div class="p-3 bg-emerald-100 rounded-xl">
          <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path>
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Total Cost</p>
          <p class="text-3xl font-bold text-indigo-600 mt-1"><%= @build.total_cost_cents ? number_to_currency(@build.total_cost_cents / 100.0) : '—' %></p>
        </div>
        <div class="p-3 bg-indigo-100 rounded-xl">
          <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Components List -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="p-4 border-b border-slate-100">
      <h3 class="font-medium text-slate-800">Components in this Build</h3>
    </div>
    <% if @build_components.any? %>
      <table class="min-w-full divide-y divide-slate-100">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Component</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Manufacturer</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Weight</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">MSRP</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @build_components.each do |bc| %>
            <tr class="hover:bg-sky-50/50 transition-colors">
              <td class="px-6 py-4">
                <a href="/admin/components/<%= bc.component.id %>" class="font-medium text-sky-600 hover:text-sky-700"><%= bc.component.name %></a>
              </td>
              <td class="px-6 py-4 text-slate-600">
                <a href="/admin/manufacturers/<%= bc.component.manufacturer.id %>" class="hover:text-sky-600"><%= bc.component.manufacturer.name %></a>
              </td>
              <td class="px-6 py-4">
                <span class="px-2.5 py-1 text-xs font-medium bg-slate-100 text-slate-600 rounded-full"><%= bc.component.type %></span>
              </td>
              <td class="px-6 py-4 text-sm text-slate-500">
                <%= bc.component.weight_oz ? "#{bc.component.weight_oz} oz" : '—' %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-500">
                <%= bc.component.msrp_cents ? number_to_currency(bc.component.msrp_cents / 100.0) : '—' %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-500">
                <%= bc.notes.present? ? bc.notes : '—' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-8 text-center text-slate-500">
        No components in this build yet.
      </div>
    <% end %>
  </div>

  <!-- Build Notes -->
  <% if @build.notes.present? %>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <h3 class="font-medium text-slate-800 mb-3">Build Notes</h3>
      <p class="text-slate-600"><%= @build.notes %></p>
    </div>
  <% end %>
</div>
