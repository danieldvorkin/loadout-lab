<div class="max-w-2xl mx-auto space-y-6">
  <!-- Breadcrumb -->
  <nav class="flex items-center space-x-2 text-sm">
    <a href="/admin/users" class="text-sky-600 hover:text-sky-700">Users</a>
    <span class="text-slate-400">/</span>
    <a href="/admin/users/<%= @user.id %>" class="text-sky-600 hover:text-sky-700"><%= @user.username %></a>
    <span class="text-slate-400">/</span>
    <span class="text-slate-600">Edit</span>
  </nav>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
    <h1 class="text-2xl font-bold text-slate-800 mb-6">Edit User</h1>

    <form action="/admin/users/<%= @user.id %>" method="post" class="space-y-6">
      <input type="hidden" name="_method" value="patch">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      
      <% if @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-xl p-4">
          <h3 class="text-sm font-medium text-red-800 mb-2">Please fix the following errors:</h3>
          <ul class="list-disc list-inside text-sm text-red-700">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label for="user_username" class="block text-sm font-medium text-slate-700 mb-1">Username</label>
        <input type="text" name="user[username]" id="user_username" value="<%= @user.username %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all">
      </div>

      <div>
        <label for="user_email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
        <input type="email" name="user[email]" id="user_email" value="<%= @user.email %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all">
      </div>

      <div>
        <label for="user_full_name" class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
        <input type="text" name="user[full_name]" id="user_full_name" value="<%= @user.full_name %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all">
      </div>

      <div>
        <label for="user_phone_number" class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
        <input type="text" name="user[phone_number]" id="user_phone_number" value="<%= @user.phone_number %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all">
      </div>

      <div>
        <label for="user_role" class="block text-sm font-medium text-slate-700 mb-1">Role</label>
        <select name="user[role]" id="user_role" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all">
          <option value="user" <%= 'selected' if @user.role == 'user' %>>User</option>
          <option value="admin" <%= 'selected' if @user.role == 'admin' %>>Admin</option>
        </select>
      </div>

      <div class="flex items-center justify-end space-x-4 pt-4">
        <a href="/admin/users/<%= @user.id %>" class="px-4 py-2 text-sm font-medium text-slate-700 hover:text-slate-900">Cancel</a>
        <button type="submit" class="px-6 py-3 bg-gradient-to-r from-sky-500 to-indigo-500 text-white font-semibold rounded-xl hover:from-sky-600 hover:to-indigo-600 shadow-lg shadow-sky-500/25 transition-all cursor-pointer">Update User</button>
      </div>
    </form>
  </div>
</div>
