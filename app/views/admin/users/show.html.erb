<div class="space-y-6">
  <!-- Breadcrumb -->
  <nav class="flex items-center space-x-2 text-sm">
    <a href="/admin/users" class="text-sky-600 hover:text-sky-700">Users</a>
    <span class="text-slate-400">/</span>
    <span class="text-slate-600"><%= @user.username %></span>
  </nav>

  <!-- User Header -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
    <div class="flex items-start justify-between">
      <div class="flex items-center space-x-4">
        <div class="w-16 h-16 bg-gradient-to-br from-sky-400 to-indigo-500 rounded-2xl flex items-center justify-center text-white text-2xl font-bold">
          <%= @user.username[0].upcase %>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-slate-800"><%= @user.username %></h1>
          <p class="text-slate-500"><%= @user.email %></p>
          <div class="flex items-center space-x-3 mt-2">
            <span class="px-2.5 py-1 text-xs font-medium rounded-full <%= @user.admin? ? 'bg-indigo-100 text-indigo-700' : 'bg-slate-100 text-slate-600' %>">
              <%= @user.role %>
            </span>
            <span class="text-sm text-slate-400">Joined <%= @user.created_at.strftime('%B %d, %Y') %></span>
          </div>
        </div>
      </div>
      <div class="flex items-center space-x-3">
        <a href="/admin/users/<%= @user.id %>/edit" class="px-4 py-2 text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors">Edit</a>
        <form action="/admin/users/<%= @user.id %>" method="post" class="inline" onsubmit="return confirm('Are you sure? This will delete all their builds.');">
          <input type="hidden" name="_method" value="delete">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" class="px-4 py-2 text-sm font-medium text-red-600 hover:text-red-700 hover:bg-red-50 rounded-xl transition-colors">Delete</button>
        </form>
      </div>
    </div>
  </div>

  <!-- User Details -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <h3 class="text-sm font-medium text-slate-500 mb-4">Account Details</h3>
      <dl class="space-y-3">
        <div>
          <dt class="text-xs text-slate-400">Full Name</dt>
          <dd class="text-slate-800"><%= @user.full_name.presence || '—' %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Phone</dt>
          <dd class="text-slate-800"><%= @user.phone_number.presence || '—' %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Location</dt>
          <dd class="text-slate-800"><%= @user.location.presence || '—' %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Discipline</dt>
          <dd class="text-slate-800"><%= @user.preferred_discipline.presence || '—' %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-400">Last Updated</dt>
          <dd class="text-slate-800"><%= @user.updated_at.strftime('%b %d, %Y at %I:%M %p') %></dd>
        </div>
      </dl>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <h3 class="text-sm font-medium text-slate-500 mb-4">Profile</h3>
      <dl class="space-y-3">
        <% if @user.bio.present? %>
          <div>
            <dt class="text-xs text-slate-400">Bio</dt>
            <dd class="text-slate-800 text-sm"><%= truncate(@user.bio, length: 150) %></dd>
          </div>
        <% end %>
        <% if @user.website.present? %>
          <div>
            <dt class="text-xs text-slate-400">Website</dt>
            <dd class="text-slate-800 truncate"><a href="<%= @user.website %>" target="_blank" class="text-sky-600 hover:text-sky-700 underline"><%= @user.website %></a></dd>
          </div>
        <% end %>
        <% if @user.date_of_birth.present? %>
          <div>
            <dt class="text-xs text-slate-400">Date of Birth</dt>
            <dd class="text-slate-800"><%= @user.date_of_birth.strftime('%B %d, %Y') %></dd>
          </div>
        <% end %>
        <% if @user.social_links.present? && @user.social_links.any? %>
          <div>
            <dt class="text-xs text-slate-400">Social Links</dt>
            <dd class="text-slate-800">
              <div class="flex flex-wrap gap-2">
                <% @user.social_links.each do |platform, handle| %>
                  <span class="px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded"><%= platform %>: <%= handle %></span>
                <% end %>
              </div>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>

    <div class="lg:col-span-1 bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <h3 class="text-sm font-medium text-slate-500 mb-4">Preferences</h3>
      <dl class="space-y-3">
        <% if @user.notification_preferences.present? %>
          <div>
            <dt class="text-xs text-slate-400">Email Updates</dt>
            <dd>
              <span class="px-2 py-1 text-xs font-medium rounded <%= @user.notification_preferences['email_updates'] ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-600' %>">
                <%= @user.notification_preferences['email_updates'] ? 'Enabled' : 'Disabled' %>
              </span>
            </dd>
          </div>
          <div>
            <dt class="text-xs text-slate-400">Build Notifications</dt>
            <dd>
              <span class="px-2 py-1 text-xs font-medium rounded <%= @user.notification_preferences['build_notifications'] ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-600' %>">
                <%= @user.notification_preferences['build_notifications'] ? 'Enabled' : 'Disabled' %>
              </span>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <!-- Builds Section -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
    <h3 class="text-sm font-medium text-slate-500 mb-4">Builds (<%= @builds.count %>)</h3>
    <% if @builds.any? %>
      <div class="space-y-3">
        <% @builds.each do |build| %>
          <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl">
            <div>
              <p class="font-medium text-slate-800"><%= build.name %></p>
              <p class="text-sm text-slate-500">
                <%= build.build_components.count %> components
                <% if build.discipline %>
                  · <span class="text-sky-600"><%= build.discipline %></span>
                <% end %>
              </p>
            </div>
            <span class="text-xs text-slate-400"><%= time_ago_in_words(build.created_at) %> ago</span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-500 text-center py-8">No builds yet</p>
    <% end %>
  </div>
</div>
