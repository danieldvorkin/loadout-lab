<div class="space-y-6">
  <!-- Breadcrumb -->
  <nav class="flex items-center space-x-2 text-sm">
    <a href="/admin/manufacturers" class="text-sky-600 hover:text-sky-700">Manufacturers</a>
    <span class="text-slate-400">/</span>
    <span class="text-slate-600"><%= @manufacturer.name %></span>
  </nav>

  <!-- Manufacturer Header -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-800"><%= @manufacturer.name %></h1>
        <% if @manufacturer.website.present? %>
          <a href="<%= @manufacturer.website %>" target="_blank" rel="noopener" class="text-sky-600 hover:text-sky-700 mt-1 inline-block"><%= @manufacturer.website %></a>
        <% end %>
      </div>
      <div class="flex items-center space-x-3">
        <a href="/admin/manufacturers/<%= @manufacturer.id %>/edit" class="px-4 py-2 text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors">Edit</a>
        <form action="/admin/manufacturers/<%= @manufacturer.id %>" method="post" class="inline" onsubmit="return confirm('Are you sure? This will affect all related components.');">
          <input type="hidden" name="_method" value="delete">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" class="px-4 py-2 text-sm font-medium text-red-600 hover:text-red-700 hover:bg-red-50 rounded-xl transition-colors">Delete</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Total Components</p>
          <p class="text-3xl font-bold text-slate-800 mt-1"><%= @manufacturer.components.count %></p>
        </div>
        <div class="p-3 bg-sky-100 rounded-xl">
          <svg class="w-6 h-6 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Active Components</p>
          <p class="text-3xl font-bold text-emerald-600 mt-1"><%= @manufacturer.components.where(discontinued: false).count %></p>
        </div>
        <div class="p-3 bg-emerald-100 rounded-xl">
          <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Discontinued</p>
          <p class="text-3xl font-bold text-red-600 mt-1"><%= @manufacturer.components.where(discontinued: true).count %></p>
        </div>
        <div class="p-3 bg-red-100 rounded-xl">
          <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Components List -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="p-4 border-b border-slate-100">
      <h3 class="font-medium text-slate-800">Components by <%= @manufacturer.name %></h3>
    </div>
    <% if @manufacturer.components.any? %>
      <table class="min-w-full divide-y divide-slate-100">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Component</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-slate-600 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @manufacturer.components.limit(20).each do |component| %>
            <tr class="hover:bg-sky-50/50 transition-colors">
              <td class="px-6 py-4 font-medium text-slate-800"><%= component.name %></td>
              <td class="px-6 py-4">
                <span class="px-2.5 py-1 text-xs font-medium bg-slate-100 text-slate-600 rounded-full"><%= component.type %></span>
              </td>
              <td class="px-6 py-4">
                <% if component.discontinued %>
                  <span class="px-2.5 py-1 text-xs font-medium bg-red-50 text-red-600 rounded-full">Discontinued</span>
                <% else %>
                  <span class="px-2.5 py-1 text-xs font-medium bg-emerald-50 text-emerald-600 rounded-full">Active</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right">
                <a href="/admin/components/<%= component.id %>" class="text-sky-600 hover:text-sky-700 text-sm font-medium">View</a>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if @manufacturer.components.count > 20 %>
        <div class="p-4 text-center text-sm text-slate-500 border-t border-slate-100">
          Showing 20 of <%= @manufacturer.components.count %> components. <a href="/admin/components?manufacturer_id=<%= @manufacturer.id %>" class="text-sky-600 hover:text-sky-700">View all</a>
        </div>
      <% end %>
    <% else %>
      <div class="p-8 text-center text-slate-500">
        No components yet. <a href="/admin/components/new" class="text-sky-600 hover:text-sky-700">Add the first one</a>
      </div>
    <% end %>
  </div>

  <!-- Timestamps -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
    <div class="flex items-center justify-between text-sm text-slate-500">
      <span>Created: <%= @manufacturer.created_at.strftime('%B %d, %Y at %I:%M %p') %></span>
      <span>Last updated: <%= @manufacturer.updated_at.strftime('%B %d, %Y at %I:%M %p') %></span>
    </div>
  </div>
</div>
