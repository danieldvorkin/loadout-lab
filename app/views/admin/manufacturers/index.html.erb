<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-800">Manufacturers</h1>
      <p class="text-slate-600 mt-1">Manage all manufacturers in the database</p>
    </div>
    <a href="/admin/manufacturers/new" class="px-4 py-2 bg-gradient-to-r from-sky-500 to-indigo-500 text-white font-semibold rounded-xl hover:from-sky-600 hover:to-indigo-600 shadow-lg shadow-sky-500/25 transition-all">Add Manufacturer</a>
  </div>

  <!-- Search -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4">
    <form action="/admin/manufacturers" method="get" class="flex flex-wrap items-center gap-4">
      <div class="flex-1 min-w-[200px]">
        <input type="text" name="search" value="<%= params[:search] %>" placeholder="Search by manufacturer name..." 
               class="w-full px-4 py-2 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent">
      </div>
      <button type="submit" class="px-4 py-2 bg-sky-500 text-white font-medium rounded-xl hover:bg-sky-600 transition-colors cursor-pointer">Search</button>
      <% if params[:search].present? %>
        <a href="/admin/manufacturers" class="px-4 py-2 text-slate-600 hover:text-slate-800">Clear</a>
      <% end %>
    </form>
  </div>

  <!-- Manufacturers Table -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="min-w-full divide-y divide-slate-100">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Website</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Components</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 uppercase tracking-wider">Created</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-slate-600 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @manufacturers.each do |manufacturer| %>
          <tr class="hover:bg-sky-50/50 transition-colors">
            <td class="px-6 py-4">
              <p class="font-medium text-slate-800"><%= manufacturer.name %></p>
            </td>
            <td class="px-6 py-4">
              <% if manufacturer.website.present? %>
                <a href="<%= manufacturer.website %>" target="_blank" rel="noopener" class="text-sky-600 hover:text-sky-700 text-sm truncate max-w-xs block"><%= manufacturer.website %></a>
              <% else %>
                <span class="text-slate-400">—</span>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <span class="px-2.5 py-1 text-xs font-medium bg-slate-100 text-slate-600 rounded-full">
                <%= manufacturer.components.count %> components
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500">
              <%= manufacturer.created_at.strftime('%b %d, %Y') %>
            </td>
            <td class="px-6 py-4 text-right space-x-2">
              <a href="/admin/manufacturers/<%= manufacturer.id %>" class="text-sky-600 hover:text-sky-700 text-sm font-medium">View</a>
              <a href="/admin/manufacturers/<%= manufacturer.id %>/edit" class="text-slate-600 hover:text-slate-700 text-sm font-medium">Edit</a>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if @manufacturers.respond_to?(:total_pages) && @manufacturers.total_pages > 1 %>
    <div class="flex justify-center">
      <nav class="flex items-center space-x-2">
        <% if @manufacturers.current_page > 1 %>
          <a href="/admin/manufacturers?page=<%= @manufacturers.current_page - 1 %>" class="px-3 py-2 text-sm text-slate-600 hover:bg-slate-100 rounded-lg">Previous</a>
        <% end %>
        <span class="px-3 py-2 text-sm text-slate-600">Page <%= @manufacturers.current_page %> of <%= @manufacturers.total_pages %></span>
        <% if @manufacturers.current_page < @manufacturers.total_pages %>
          <a href="/admin/manufacturers?page=<%= @manufacturers.current_page + 1 %>" class="px-3 py-2 text-sm text-slate-600 hover:bg-slate-100 rounded-lg">Next</a>
        <% end %>
      </nav>
    </div>
  <% end %>
</div>
