<div class="min-h-[80vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold bg-gradient-to-r from-sky-600 to-indigo-600 bg-clip-text text-transparent">
        Loadout Lab
      </h1>
      <p class="mt-2 text-slate-600">Admin Panel</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
      <h2 class="text-xl font-semibold text-slate-800 mb-6">Sign in to Admin</h2>

      <form action="/admin/login" method="post" class="space-y-6">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" name="email" id="email" required autofocus
                 class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all"
                 placeholder="admin@example.com">
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Password</label>
          <input type="password" name="password" id="password" required
                 class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all"
                 placeholder="••••••••">
        </div>

        <button type="submit"
                class="w-full py-3 px-4 bg-gradient-to-r from-sky-500 to-indigo-500 text-white font-semibold rounded-xl hover:from-sky-600 hover:to-indigo-600 shadow-lg shadow-sky-500/25 transition-all">
          Sign In
        </button>
      </form>
    </div>
  </div>
</div>
