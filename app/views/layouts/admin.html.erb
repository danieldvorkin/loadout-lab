<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Loadout Lab Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: { 50: '#f0f9ff', 100: '#e0f2fe', 500: '#0ea5e9', 600: '#0284c7', 700: '#0369a1' },
            accent: { 50: '#eef2ff', 100: '#e0e7ff', 500: '#6366f1', 600: '#4f46e5' }
          }
        }
      }
    }
  </script>
  <%= csrf_meta_tags %>
</head>
<body class="bg-slate-50 min-h-screen">
  <% if current_user&.admin? %>
    <!-- Navigation -->
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <a href="/admin" class="flex items-center">
              <span class="text-xl font-bold bg-gradient-to-r from-sky-600 to-indigo-600 bg-clip-text text-transparent">
                Loadout Lab
              </span>
              <span class="ml-2 px-2 py-0.5 text-xs font-medium bg-indigo-100 text-indigo-700 rounded-full">Admin</span>
            </a>
            
            <div class="hidden sm:ml-8 sm:flex sm:space-x-4">
              <a href="/admin" 
                  class="px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= request.path == '/admin' ? 'bg-sky-50 text-sky-700' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50' %>">Dashboard</a>
              <a href="/admin/users" 
                  class="px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= request.path.start_with?('/admin/users') ? 'bg-sky-50 text-sky-700' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50' %>">Users</a>
              <a href="/admin/builds" 
                  class="px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= request.path.start_with?('/admin/builds') ? 'bg-sky-50 text-sky-700' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50' %>">Builds</a>
              <a href="/admin/components" 
                  class="px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= request.path.start_with?('/admin/components') ? 'bg-sky-50 text-sky-700' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50' %>">Components</a>
              <a href="/admin/manufacturers" 
                  class="px-3 py-2 text-sm font-medium rounded-lg transition-colors <%= request.path.start_with?('/admin/manufacturers') ? 'bg-sky-50 text-sky-700' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50' %>">Manufacturers</a>
            </div>
          </div>
          
          <div class="flex items-center space-x-4">
            <span class="text-sm text-slate-600"><%= current_user.email %></span>
            <form action="/admin/logout" method="post" class="inline">
              <input type="hidden" name="_method" value="delete">
              <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
              <button type="submit" class="px-3 py-1.5 text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-colors cursor-pointer">Logout</button>
            </form>
          </div>
        </div>
      </div>
    </nav>
  <% end %>

  <!-- Flash Messages -->
  <% if notice %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl">
        <%= notice %>
      </div>
    </div>
  <% end %>
  <% if alert %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl">
        <%= alert %>
      </div>
    </div>
  <% end %>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%= yield %>
  </main>
</body>
</html>
